{
  "mcpServers": {
    "n8n": {
      "command": "npx",
      "args": ["-y", "-p", "dotenv-cli", "dotenv", "--", "npx", "-y", "n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "TELEMETRY_ENABLED": "false"
      }
    }
  }
}
